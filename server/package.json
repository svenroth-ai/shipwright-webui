{
  "name": "shipwright-command-center-server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../.env.local src/index.ts",
    "dev:fresh": "node ../scripts/dev-restart.js",
    "build": "tsc && node scripts/copy-assets.mjs",
    "start": "node dist/index.js",
    "test": "vitest"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/node-ws": "^1.3.1",
    "@lydell/node-pty": "^1.1.0",
    "@xterm/addon-serialize": "0.14.0",
    "@xterm/headless": "6.0.0",
    "hono": "^4.7.0",
    "ignore": "^5.3.2",
    "p-queue": "^9.2.0",
    "proper-lockfile": "^4.1.0",
    "shell-quote": "^1.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/shell-quote": "^1.7.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

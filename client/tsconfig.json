{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "src/lib/resolveTailscaleIp.ts",
    "src/lib/resolveTailscaleIp.test.ts",
    "src/lib/resolveNetworkProfile.ts",
    "src/lib/resolveNetworkProfile.test.ts",
    "src/lib/resolveProxyTarget.ts",
    "src/lib/resolveProxyTarget.test.ts"
  ]
}

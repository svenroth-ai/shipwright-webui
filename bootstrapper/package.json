{
  "name": "@svenroth-ai/shipwright",
  "version": "0.23.0",
  "description": "One command to install AND update Shipwright — the /shipwright-* SDLC plugins and the Command Center. Run `npx @svenroth-ai/shipwright@latest`.",
  "type": "module",
  "bin": {
    "shipwright": "bin/shipwright.mjs"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/deploy-swap.mjs",
    "scripts/deploy-procs.mjs",
    "scripts/repair-claude-json.mjs",
    "scripts/kill-targets.js",
    "server/dist/",
    "server/profiles/",
    "server/package.json",
    "client/dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build-package.mjs",
    "prepack": "node scripts/build-package.mjs",
    "test": "vitest run",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "shipwright",
    "claude-code",
    "sdlc",
    "installer",
    "bootstrapper"
  ],
  "author": "svenroth.ai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/svenroth-ai/shipwright-webui.git",
    "directory": "bootstrapper"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/node-ws": "^1.3.1",
    "@lydell/node-pty": "^1.1.0",
    "@xterm/addon-serialize": "0.14.0",
    "@xterm/headless": "6.0.0",
    "hono": "^4.12.25",
    "ignore": "^5.3.2",
    "p-queue": "^9.2.0",
    "proper-lockfile": "^4.1.0",
    "shell-quote": "^1.8.4"
  },
  "devDependencies": {
    "oxlint": "^1.66.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "ws": "^8.21.0"
  }
}

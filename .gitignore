# Build / dependencies
node_modules/
dist/
*.tsbuildinfo

# Local env / secrets (never commit)
.env
.env.*
!.env.example

# Test / report artifacts (auto-generated)
client/e2e-results.json
client/playwright-report/
client/test-results/
client/e2e/_minimal-*.png
client/e2e/_probe-*.png
shipwright_audit_report.json

# === .shipwright/ Artefakt-Whitelist (kongruent zum Monorepo) ===
# Alles ignorieren, nur die kanonischen SDLC-Doku-Heimaten freigeben.
/.shipwright/*
!/.shipwright/adopt/
!/.shipwright/agent_docs/
!/.shipwright/compliance/
!/.shipwright/designs/
!/.shipwright/planning/
# Transiente / interne / generierte Inhalte wieder ausschliessen:
/.shipwright/adopt/backups/
/.shipwright/adopt/screenshots/
/.shipwright/agent_docs/decision-drops/
/.shipwright/agent_docs/visual/
/.shipwright/agent_docs/runtime/
/.shipwright/agent_docs/triage-remaining-iterates-handoff.md
/.shipwright/compliance/skill-compliance/

# === Root shipwright_* Self-Adoption-State ===
# Default: ignorieren. Ausnahmen: persistente Configs/Events werden bewusst getrackt.
shipwright_*_config.json
shipwright_test_results.json
shipwright_events.jsonl
shipwright_events.jsonl.lock
!/shipwright_build_config.json
!/shipwright_compliance_config.json
!/shipwright_iterate_config.json
!/shipwright_plan_config.json
!/shipwright_project_config.json
!/shipwright_run_config.json
!/shipwright_sync_config.json
!/shipwright_test_results.json
!/shipwright_events.jsonl

# Root-Locks (multi-writer State)
CHANGELOG.md.lock
shipwright_run_config.json.lock
.shipwright_toolcall_count

# Lokale Git-Worktrees nie committen
/.worktrees/

# Isolated USERPROFILE used by iterate F0.5 E2E (not part of any source set)
/.e2e-userprofile/

# Lokaler VS-Code-Multi-Root-Workspace
/.shipwright-webui/

# Local launch-prep / one-shot scrub tooling
/.scrub.py

# === BEGIN Shipwright canonical .shipwright artifact-ignore (managed) ===
# Managed by Shipwright (adopt/project). Do not hand-edit — re-running
# /shipwright-adopt or /shipwright-project back-fills missing rules.
# SSoT: shared/templates/shipwright-gitignore.template
!/.shipwright/triage.jsonl
/.shipwright/triage.outbox.jsonl
**/.shipwright/locks/
/.shipwright/compliance/audit-report.md
/.shipwright/compliance/audit-report.json
/.shipwright/planning/iterate/**/external_review_state.json
/.shipwright/planning/iterate/**/external_code_review_state.json
/.shipwright/planning/iterate/campaigns/
# === END Shipwright canonical .shipwright artifact-ignore (managed) ===

# Triage Inbox (shipwright)
.shipwright/triage.jsonl.lock
.shipwright/triage.jsonl.bak
